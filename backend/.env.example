# 复制为 .env 并填入真实值

# 数据库连接（生产环境替换为实际地址）
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/qiblog

# JWT 密钥（生产环境必须改为随机长字符串）
SECRET_KEY=your-super-secret-key-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# 管理员账号初始化（首次启动时自动创建）
# 密码哈希用 passlib 生成：python -c "from passlib.context import CryptContext; print(CryptContext(schemes=['bcrypt']).hash('your_password'))"
ADMIN_USERNAME=qi
ADMIN_PASSWORD_HASH=
ADMIN_EMAIL=qi@example.com

# CORS 允许的前端域名（逗号分隔，生产环境替换为真实域名）
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# DeepSeek API（用于水豚祁 AI 聊天）
DEEPSEEK_API_KEY=your-deepseek-api-key

# 图片存储目录（生产环境必须设为 nginx 实际提供服务的 /photos/ 目录绝对路径）
# 默认为开发时的 frontend/public/photos/，生产部署时需修改
# PHOTOS_DIR=/var/www/qi-blog/photos
